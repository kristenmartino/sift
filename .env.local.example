# Anthropic API key (required)
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Pre-warm all categories on server start (optional, default: off)
# Enable on long-running servers to reduce first-request latency.
# Leave unset or set to "false" on serverless (Vercel) to avoid cold-start cost.
# SIFT_PREWARM=true
