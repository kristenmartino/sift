# Copy to .env.local and fill in. Values here are placeholders.

# ── Database (read path) ──────────────────────────────
# Neon Postgres connection string.
DATABASE_URL=postgresql://user:password@host/dbname

# ── Auth (Clerk) ──────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# ── AI / topic-search read-path fallback (grandfathered — see DECISIONS D35) ──
ANTHROPIC_API_KEY=sk-ant-xxx
VOYAGE_API_KEY=pa-xxx

# ── Backend proxy (multi-source compare) ──────────────
SIFT_API_URL=http://localhost:8000
SIFT_API_KEY=dev-key

# ── Error monitoring (Sentry) — OPTIONAL ──────────────
# Sentry is INERT unless this DSN is set. It's a public value (the browser SDK
# uses it), and the same DSN drives client + server + edge. No PII is sent.
NEXT_PUBLIC_SENTRY_DSN=
# Source-map upload ONLY. Set these in CI/deploy for readable stack traces.
# Builds without them simply skip the upload — they never block the build.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
